{
  "info": {
    "name": "License Management API",
    "description": "API для управления лицензиями - создание, активация, проверка, продление",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://localhost:8443",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "licenseCode",
      "value": "",
      "type": "string"
    },
    {
      "key": "deviceMac",
      "value": "00:1B:44:11:3A:B7",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Аутентификация",
      "item": [
        {
          "name": "1.1 Логин администратора",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@photoprint.com\",\n    \"password\": \"Test123!@#\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set(\"adminToken\", jsonData.accessToken);",
                  "console.log(\"Admin Token set:\", jsonData.accessToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "1.2 Логин пользователя",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"ivan@example.com\",\n    \"password\": \"Test123!@#\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set(\"userToken\", jsonData.accessToken);",
                  "console.log(\"User Token set:\", jsonData.accessToken);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Продукты",
      "item": [
        {
          "name": "2.1 Получить все продукты",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            }
          }
        },
        {
          "name": "2.2 Создать продукт (ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"PhotoPrint Enterprise\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Типы лицензий",
      "item": [
        {
          "name": "3.1 Получить все типы лицензий",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/license-types",
              "host": ["{{baseUrl}}"],
              "path": ["license-types"]
            }
          }
        },
        {
          "name": "3.2 Создать тип лицензии (ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"QUARTER\",\n    \"defaultDurationInDays\": 90,\n    \"description\": \"Квартальная лицензия\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/license-types",
              "host": ["{{baseUrl}}"],
              "path": ["license-types"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Устройства",
      "item": [
        {
          "name": "4.1 Зарегистрировать устройство",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"macAddress\": \"AA:BB:CC:DD:EE:FF\",\n    \"name\": \"Ноутбук Ивана\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/devices/register",
              "host": ["{{baseUrl}}"],
              "path": ["devices", "register"]
            }
          }
        },
        {
          "name": "4.2 Получить все устройства пользователя",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/devices",
              "host": ["{{baseUrl}}"],
              "path": ["devices"]
            }
          }
        }
      ]
    },
    {
      "name": "5. Лицензии",
      "item": [
        {
          "name": "5.1 Создать лицензию (ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"productId\": 1,\n    \"typeId\": 2,\n    \"ownerId\": 2,\n    \"deviceCount\": 3,\n    \"description\": \"Годовая лицензия для Ивана\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/licenses/create",
              "host": ["{{baseUrl}}"],
              "path": ["licenses", "create"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.code) {",
                  "    pm.environment.set(\"licenseCode\", jsonData.code);",
                  "    console.log(\"License Code:\", jsonData.code);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "5.2 Активировать лицензию",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"activationKey\": \"{{licenseCode}}\",\n    \"deviceMac\": \"AA:BB:CC:DD:EE:FF\",\n    \"deviceName\": \"Ноутбук Ивана\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/licenses/activate",
              "host": ["{{baseUrl}}"],
              "path": ["licenses", "activate"]
            }
          }
        },
        {
          "name": "5.3 Проверить лицензию",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"deviceMac\": \"AA:BB:CC:DD:EE:FF\",\n    \"productId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/licenses/check",
              "host": ["{{baseUrl}}"],
              "path": ["licenses", "check"]
            }
          }
        },
        {
          "name": "5.4 Получить лицензию по коду",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/licenses/{{licenseCode}}",
              "host": ["{{baseUrl}}"],
              "path": ["licenses", "{{licenseCode}}"]
            }
          }
        },
        {
          "name": "5.5 Получить все лицензии пользователя",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/licenses/user",
              "host": ["{{baseUrl}}"],
              "path": ["licenses", "user"]
            }
          }
        },
        {
          "name": "5.6 Продлить лицензию",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"activationKey\": \"{{licenseCode}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/licenses/renew",
              "host": ["{{baseUrl}}"],
              "path": ["licenses", "renew"]
            }
          }
        }
      ]
    },
    {
      "name": "6. Ticket",
      "item": [
        {
          "name": "6.1 Получить Ticket",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"macAddress\": \"AA:BB:CC:DD:EE:FF\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/licenses/{{licenseCode}}/ticket",
              "host": ["{{baseUrl}}"],
              "path": ["licenses", "{{licenseCode}}", "ticket"]
            }
          }
        }
      ]
    }
  ]
}