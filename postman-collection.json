{
  "info": {
    "name": "Anti-Malware Signatures API",
    "description": "API для управления антивирусными сигнатурами с ЭЦП",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://localhost:8443",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminAccessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "signatureId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "0. Аутентификация",
      "item": [
        {
          "name": "Login as User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.accessToken) {",
                  "    pm.environment.set(\"accessToken\", jsonData.accessToken);",
                  "    console.log(\"User token saved\");",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"test@example.com\",\n    \"password\": \"Test123!@#\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Login as Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.accessToken) {",
                  "    pm.environment.set(\"adminAccessToken\", jsonData.accessToken);",
                  "    console.log(\"Admin token saved\");",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"nser@example.com\",\n    \"password\": \"Test123!@#\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "1. Чтение сигнатур (требуется认证)",
      "item": [
        {
          "name": "1.1 Получить все активные сигнатуры",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/signatures",
              "host": ["{{baseUrl}}"],
              "path": ["signatures"]
            }
          }
        },
        {
          "name": "1.2 Получить сигнатуру по ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/signatures/{{signatureId}}",
              "host": ["{{baseUrl}}"],
              "path": ["signatures", "{{signatureId}}"]
            }
          }
        },
        {
          "name": "1.3 Инкрементальный экспорт (с момента)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/signatures/export/incremental?since=2024-01-01T00:00:00Z",
              "host": ["{{baseUrl}}"],
              "path": ["signatures", "export", "incremental"],
              "query": [
                {
                  "key": "since",
                  "value": "2024-01-01T00:00:00Z"
                }
              ]
            }
          }
        },
        {
          "name": "1.4 Получить сигнатуры по списку ID",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"ids\": [\"{{signatureId}}\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/signatures/export/by-ids",
              "host": ["{{baseUrl}}"],
              "path": ["signatures", "export", "by-ids"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Создание сигнатур (только ADMIN)",
      "item": [
        {
          "name": "2.1 Создать сигнатуру Win32.Trojan",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.id) {",
                  "    pm.environment.set(\"signatureId\", jsonData.id);",
                  "    console.log(\"Signature ID saved:\", jsonData.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"threatName\": \"Win32.Trojan.Generic\",\n    \"firstBytesHex\": \"4D5A90000300000004000000FFFF\",\n    \"remainderHashHex\": \"e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855\",\n    \"remainderLength\": 1024,\n    \"fileType\": \"PE32\",\n    \"offsetStart\": 0,\n    \"offsetEnd\": 128\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/signatures",
              "host": ["{{baseUrl}}"],
              "path": ["signatures"]
            }
          }
        },
        {
          "name": "2.2 Создать сигнатуру Linux.Mirai",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"threatName\": \"Linux.Mirai.Botnet\",\n    \"firstBytesHex\": \"7F454C46020101000000000000000000\",\n    \"remainderHashHex\": \"6b86b273ff34fce19d6b804eff5a3f5747ada4eaa22f1d49c01e52ddb7875b4b\",\n    \"remainderLength\": 2048,\n    \"fileType\": \"ELF\",\n    \"offsetStart\": 0,\n    \"offsetEnd\": 256\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/signatures",
              "host": ["{{baseUrl}}"],
              "path": ["signatures"]
            }
          }
        },
        {
          "name": "2.3 Создать сигнатуру PDF.Exploit",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"threatName\": \"PDF.Exploit.CVE-2023-XXXX\",\n    \"firstBytesHex\": \"255044462D312E340A25C7EC8FA20A\",\n    \"remainderHashHex\": \"d4735e3a265e16eee03f59718b9b5d03019c07d8b6c51f90da3a666eec13ab35\",\n    \"remainderLength\": 512,\n    \"fileType\": \"PDF\",\n    \"offsetStart\": 0,\n    \"offsetEnd\": 64\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/signatures",
              "host": ["{{baseUrl}}"],
              "path": ["signatures"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Обновление сигнатур (только ADMIN)",
      "item": [
        {
          "name": "3.1 Обновить сигнатуру",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"threatName\": \"Win32.Trojan.Generic.Updated\",\n    \"firstBytesHex\": \"4D5A90000300000004000000FFFF\",\n    \"remainderHashHex\": \"e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855\",\n    \"remainderLength\": 2048,\n    \"fileType\": \"PE32+\",\n    \"offsetStart\": 0,\n    \"offsetEnd\": 256\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/signatures/{{signatureId}}",
              "host": ["{{baseUrl}}"],
              "path": ["signatures", "{{signatureId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Удаление сигнатур (только ADMIN)",
      "item": [
        {
          "name": "4.1 Удалить сигнатуру (логическое)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/signatures/{{signatureId}}",
              "host": ["{{baseUrl}}"],
              "path": ["signatures", "{{signatureId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "5. История и аудит (только ADMIN)",
      "item": [
        {
          "name": "5.1 Получить историю версий сигнатуры",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/signatures/{{signatureId}}/history",
              "host": ["{{baseUrl}}"],
              "path": ["signatures", "{{signatureId}}", "history"]
            }
          }
        },
        {
          "name": "5.2 Получить аудит изменений сигнатуры",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/signatures/{{signatureId}}/audit",
              "host": ["{{baseUrl}}"],
              "path": ["signatures", "{{signatureId}}", "audit"]
            }
          }
        }
      ]
    },
    {
      "name": "6. Тесты с некорректными данными",
      "item": [
        {
          "name": "6.1 Ошибка: неверный hex в firstBytesHex",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"threatName\": \"Test.InvalidHex\",\n    \"firstBytesHex\": \"ZZZZZZ\",\n    \"remainderHashHex\": \"e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855\",\n    \"remainderLength\": 1024,\n    \"fileType\": \"PE32\",\n    \"offsetStart\": 0,\n    \"offsetEnd\": 128\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/signatures",
              "host": ["{{baseUrl}}"],
              "path": ["signatures"]
            }
          }
        },
        {
          "name": "6.2 Ошибка: remainderHashHex не 64 символа",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"threatName\": \"Test.InvalidHash\",\n    \"firstBytesHex\": \"4D5A9000\",\n    \"remainderHashHex\": \"short\",\n    \"remainderLength\": 1024,\n    \"fileType\": \"PE32\",\n    \"offsetStart\": 0,\n    \"offsetEnd\": 128\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/signatures",
              "host": ["{{baseUrl}}"],
              "path": ["signatures"]
            }
          }
        },
        {
          "name": "6.3 Ошибка: offsetEnd < offsetStart",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"threatName\": \"Test.InvalidOffset\",\n    \"firstBytesHex\": \"4D5A9000\",\n    \"remainderHashHex\": \"e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855\",\n    \"remainderLength\": 1024,\n    \"fileType\": \"PE32\",\n    \"offsetStart\": 100,\n    \"offsetEnd\": 50\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/signatures",
              "host": ["{{baseUrl}}"],
              "path": ["signatures"]
            }
          }
        }
      ]
    },
    {
      "name": "7. Проверка ЭЦП сигнатур",
      "item": [
        {
          "name": "7.1 Получить сигнатуру с цифровой подписью",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/signatures/{{signatureId}}",
              "host": ["{{baseUrl}}"],
              "path": ["signatures", "{{signatureId}}"]
            }
          }
        }
      ]
    }
  ]
}