{
  "info": {
    "name": "PhotoPrint License Management API",
    "description": "API для управления лицензиями с поддержкой ЭЦП (цифровой подписи)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://localhost:8443",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "licenseCode",
      "value": "",
      "type": "string"
    },
    {
      "key": "deviceId",
      "value": "",
      "type": "string"
    },
    {
      "key": "licenseId",
      "value": "",
      "type": "string"
    },
    {
      "key": "macAddress",
      "value": "AA:BB:CC:DD:EE:FF",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Аутентификация",
      "item": [
        {
          "name": "1.1 Логин (nser@example.com - ADMIN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.accessToken) {",
                  "    pm.environment.set(\"accessToken\", jsonData.accessToken);",
                  "    pm.environment.set(\"refreshToken\", jsonData.refreshToken);",
                  "    console.log(\"Token saved successfully\");",
                  "} else {",
                  "    console.log(\"Login failed\");",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"nser@example.com\",\n    \"password\": \"Test123!@#\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "1.2 Регистрация пользователя",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Test User\",\n    \"email\": \"test@example.com\",\n    \"password\": \"Test123!@#\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "1.3 Обновление токена",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Продукты",
      "item": [
        {
          "name": "2.1 Получить все продукты",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            }
          }
        },
        {
          "name": "2.2 Создать продукт (требует ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"PhotoPrint Premium\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Типы лицензий",
      "item": [
        {
          "name": "3.1 Получить все типы лицензий",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/license-types",
              "host": ["{{baseUrl}}"],
              "path": ["license-types"]
            }
          }
        },
        {
          "name": "3.2 Создать тип лицензии (требует ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"PERPETUAL\",\n    \"defaultDurationInDays\": 36500,\n    \"description\": \"Вечная лицензия\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/license-types",
              "host": ["{{baseUrl}}"],
              "path": ["license-types"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Устройства",
      "item": [
        {
          "name": "4.1 Зарегистрировать устройство",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.id) {",
                  "    pm.environment.set(\"deviceId\", jsonData.id);",
                  "    console.log(\"Device ID saved:\", jsonData.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"macAddress\": \"{{macAddress}}\",\n    \"name\": \"Ноутбук Ивана\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/devices/register",
              "host": ["{{baseUrl}}"],
              "path": ["devices", "register"]
            }
          }
        },
        {
          "name": "4.2 Получить устройства пользователя",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/devices",
              "host": ["{{baseUrl}}"],
              "path": ["devices"]
            }
          }
        },
        {
          "name": "4.3 Получить лицензии устройства",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/devices/{{deviceId}}/licenses",
              "host": ["{{baseUrl}}"],
              "path": ["devices", "{{deviceId}}", "licenses"]
            }
          }
        }
      ]
    },
    {
      "name": "5. Лицензии",
      "item": [
        {
          "name": "5.1 Создать лицензию (требует ADMIN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.code) {",
                  "    pm.environment.set(\"licenseCode\", jsonData.code);",
                  "    pm.environment.set(\"licenseId\", jsonData.licenseId);",
                  "    console.log(\"License code saved:\", jsonData.code);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"productId\": 1,\n    \"typeId\": 2,\n    \"ownerId\": 8,\n    \"deviceCount\": 3,\n    \"description\": \"Тестовая годовая лицензия\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/licenses/create",
              "host": ["{{baseUrl}}"],
              "path": ["licenses", "create"]
            }
          }
        },
        {
          "name": "5.2 Активировать лицензию",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"activationKey\": \"{{licenseCode}}\",\n    \"deviceMac\": \"{{macAddress}}\",\n    \"deviceName\": \"Ноутбук Ивана\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/licenses/activate",
              "host": ["{{baseUrl}}"],
              "path": ["licenses", "activate"]
            }
          }
        },
        {
          "name": "5.3 Получить лицензию по коду",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/licenses/{{licenseCode}}",
              "host": ["{{baseUrl}}"],
              "path": ["licenses", "{{licenseCode}}"]
            }
          }
        },
        {
          "name": "5.4 Проверить лицензию (получить Ticket с подписью)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"deviceMac\": \"{{macAddress}}\",\n    \"productId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/licenses/check",
              "host": ["{{baseUrl}}"],
              "path": ["licenses", "check"]
            }
          }
        },
        {
          "name": "5.5 Получить Ticket по коду лицензии (с ЭЦП)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"macAddress\": \"{{macAddress}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/licenses/{{licenseCode}}/ticket",
              "host": ["{{baseUrl}}"],
              "path": ["licenses", "{{licenseCode}}", "ticket"]
            }
          }
        },
        {
          "name": "5.6 Получить все лицензии пользователя",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/licenses/user",
              "host": ["{{baseUrl}}"],
              "path": ["licenses", "user"]
            }
          }
        },
        {
          "name": "5.7 Продлить лицензию",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"activationKey\": \"{{licenseCode}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/licenses/renew",
              "host": ["{{baseUrl}}"],
              "path": ["licenses", "renew"]
            }
          }
        },
        {
          "name": "5.8 Заблокировать/разблокировать лицензию (ADMIN)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/licenses/{{licenseId}}/block?blocked=true",
              "host": ["{{baseUrl}}"],
              "path": ["licenses", "{{licenseId}}", "block"],
              "query": [
                {
                  "key": "blocked",
                  "value": "true"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "6. Проверка ЭЦП",
      "item": [
        {
          "name": "6.1 Получить Ticket с подписью (демонстрация ЭЦП)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"macAddress\": \"{{macAddress}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/licenses/{{licenseCode}}/ticket",
              "host": ["{{baseUrl}}"],
              "path": ["licenses", "{{licenseCode}}", "ticket"]
            }
          }
        }
      ]
    }
  ]
}